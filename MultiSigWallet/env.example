# Hardhat 3 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# RPC节点URL
# ============================================
# 从Infura、Alchemy等服务获取
# Infura格式: https://sepolia.infura.io/v3/YOUR-PROJECT-ID
# Alchemy格式: https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/xxxxxxxx
MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/xxxxxxxx

# ============================================
# 私钥配置（敏感信息，切勿泄露）
# ============================================
# 警告：不要提交私钥到Git仓库
# 使用测试账户的私钥，不要使用主网私钥
SEPOLIA_PRIVATE_KEY=xxxxxxxx

# ============================================
# API密钥配置
# ============================================
# Etherscan API密钥：用于合约验证
# 获取地址: https://etherscan.io/apis
ETHERSCAN_API_KEY=xxxxxxxx

# Coinmarketcap API密钥：用于Gas报告的价格转换（可选）
# 获取地址: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key

# ============================================
# 其他配置
# ============================================
# 是否生成Gas报告
REPORT_GAS=false

# 多签阈值
MULTISIG_THRESHOLD=2
# 多签钱包的owners
MULTISIG_OWNERS=0x84Ef25fd86CAe65f176df7d263f4C4E0E7CeA4c7,0x5D783fDE90ec77cc47D9043adCBA48bCb5D0Fd06,0x6ef34c39D70EfA037A544Ae13793EA50F4fd67B7
# 代理合约地址
PROXY_ADDRESS=0x25ccc5F543fE44F76BC3cFb0B5F8A9cA4fd0c2EA
# 代理合约部署时自动创建的ProxyAdmin地址
PROXY_ADMIN_ADDRESS=xxxxxxxx